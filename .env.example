# Forge — World App Mini App. Copy to `.env` and fill in. The app runs in a
# degraded/simulated mode where a credential is missing.

# ── Design agent (server-side only; the client calls /api/agent) ──
# Primary: an Anthropic API key. Fallback: a local Claude Code proxy (LAN IP so
# World App on a phone can reach your machine).
ANTHROPIC_API_KEY=
ANTHROPIC_PROXY_URL=
ANTHROPIC_PROXY_KEY=dummy
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── World ID 4.0 — developer.world.org (create an app + action, mint an RP) ──
NEXT_PUBLIC_WORLD_APP_ID=app_...
NEXT_PUBLIC_WORLD_ACTION=verify-human
NEXT_PUBLIC_WORLD_ENV=production
WORLD_RP_ID=rp_...
# RP signing key — SERVER ONLY, never a NEXT_PUBLIC_ var, never logged.
WORLD_SIGNER_PRIVATE_KEY=
WORLD_SIGNER_ADDRESS=

# ── ENS — names for created Sparks (label.<domain>) + the agent identity ──
# sepolia = ENS v2 (real on-chain subnames, free gas from a faucet). mainnet = classic v1 (costs ETH).
# NOTE: Holesky is shut down; Sepolia's classic ENS was migrated to ENS v2.
NEXT_PUBLIC_ENS_DOMAIN=forgedapp.eth
NEXT_PUBLIC_ENS_CHAIN=sepolia
NEXT_PUBLIC_AGENT_ENS=forgedapp.eth
# drpc resolves ENS v2 (CCIP-Read) reliably; publicnode was flaky for v2 calls.
ETH_RPC_URL=https://sepolia.drpc.org
# Server-only key that OWNS the parent domain. When set, publish auto-mints subnames
# (+ ENSIP-26 records) — users never pay gas. Register the parent first:
#   node scripts/register-ens-v2.mjs <label>        (mock USDC is openly mintable)
#   node scripts/setup-ens-v2-subnames.mjs <name>   (deploys + assigns the subregistry)
ENS_REGISTRAR_PRIVATE_KEY=
# v2 subregistry + shared resolver for the parent (printed by setup-ens-v2-subnames.mjs).
ENS_V2_SUBREGISTRY=
ENS_V2_RESOLVER=

# ── Walrus — decentralized storage (testnet publisher/aggregator by default) ──
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
# Optional: Walruscan explorer base (defaults to testnet)
NEXT_PUBLIC_WALRUS_EXPLORER_URL=https://walruscan.com/testnet/blob
NEXT_PUBLIC_WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
WALRUS_NETWORK=testnet
# Sui address for the Walrus CLI wallet (~/.sui/sui_config). Keystore stays local — never commit.
SUI_ADDRESS=
# Optional: public blob id for the built-in Spark catalog (stored with `walrus store`, readable by anyone)
FORGE_PUBLIC_CATALOG_BLOB_ID=
