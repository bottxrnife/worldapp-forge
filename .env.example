# ── DappDock credentials ────────────────────────────────────────────────────
# Copy to `.env`, fill in, then restart `npx expo start -c`.
# Every integration degrades gracefully: with no keys the app still runs with
# simulated verification/publishing and template-mode drafting.

# 1) The design agent (LLM with tool calling) — console.anthropic.com
EXPO_PUBLIC_ANTHROPIC_API_KEY=
# Optional override (defaults to claude-sonnet-4-5)
EXPO_PUBLIC_ANTHROPIC_MODEL=

# 2) World — developer.worldcoin.org → create an app + an incognito action.
#    Verification deep-links into World App on the same phone via the Wallet
#    Bridge, then the proof is checked against the Developer Portal.
EXPO_PUBLIC_WORLD_APP_ID=
EXPO_PUBLIC_WORLD_ACTION=verify-human

# 3) LI.FI — portal.li.fi → API key (quotes also work without one, rate-limited)
EXPO_PUBLIC_LIFI_API_KEY=
EXPO_PUBLIC_LIFI_INTEGRATOR=dappdock

# 4) ENS — namestone.com → API key for your domain. This single key unlocks:
#    (a) Publishing: a real gasless subname (label.<domain>) holding the dapp
#        manifest in text records.
#    (b) On-chain loyalty: each user's punch card / points are written to their
#        own gasless subname (m<addr>.<domain>) in the `app.loyalty` text record,
#        so the punch count lives on ENS — read back on app open, written on every
#        stamp. Without this key the app falls back to the local device cache.
EXPO_PUBLIC_NAMESTONE_API_KEY=
EXPO_PUBLIC_ENS_DOMAIN=dappdock.eth

# Mainnet RPC for ENS resolution + loyalty text-record reads (default: public node)
EXPO_PUBLIC_ETH_RPC_URL=
